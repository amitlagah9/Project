import streamlit as st
from streamlit_option_menu import option_menu

#pip install plotly
import plotly.express as px
import pandas as pd



st.set_page_config(page_title="Mera page", page_icon=":heart:", layout="wide")
df=pd.read_csv("covid.csv")
df.info()
with st.sidebar:
    opt=option_menu("Menu",options=["Home","Dataset","Preprocessing","Visualization","About"],icons=["house","file-text","activity","bar-chart","person"],default_index=0)

if opt=="Home":
    st.title("This is Home page")
    st.write("Hello world")

elif opt=="Dataset":
    t1,t2,t3=st.tabs(["Data","Info","Description"])
    with t1:
        st.dataframe(df)
    with t2:
        st.write(df.columns)
    with t3:
        st.table(df.describe())

elif opt=="Preprocessing":
    t1,t2=st.tabs(["Before-Processing","After-Processing"])
    with t1:
        st.write(df.isna().sum())
    with t2:
        
        df.drop(columns=["NewCases","NewDeaths","NewRecovered","Serious,Critical"],inplace=True)
        df.dropna(inplace=True)
        df.reset_index(drop=True,inplace=True)
        st.write(df.isna().sum())
        st.dataframe(df)
        

elif opt=="Visualization":
    t1,t2,t3=st.tabs(["Streamlit-Visualization","Plotly-Visualization","Matplotlib/Seaborn-Visualization"])
    df.drop(columns=["NewCases","NewDeaths","NewRecovered","Serious,Critical"],inplace=True)
    df.dropna(inplace=True)
    df.reset_index(drop=True,inplace=True)
    with t1:
        st.bar_chart(df,x="gender",y="daily_social_media_hours")
        st.bar_chart(df,x="gender",y="daily_social_media_hours",color="depression_lebel")

        st.scatter_chart(df,x="sleep_hours",y="daily_social_media_hours",x_label="sleep_hours",y_label="Total-Cases")
        st.scatter_chart(df,x="sleep_hours",y="daily_social_media_hours",color="depression_lebel")
        st.scatter_chart(df,x="sleep_hours",y="daily_social_media_hours",color="depression_lebel",size="daily_social_media_hours")

        st.line_chart(df,x="sleep_hours",y="daily_social_media_hours")

        st.area_chart(df,x="sleep_hours",y="daily_social_media_hours")
        st.area_chart(df,x="sleep_hours",y="daily_social_media_hours",color="depression_lebel")
    
    with t2:
