        # fig44=px.scatter(df,x="sleep_hours",y="daily_social_media_hours",color="depression_lebel",size="daily_social_media_hours",size_max=100,log_y=True,log_x=True)
        # st.plotly_chart(fig44)

        #3-d chart

        fig5=px.scatter_3d(df,x="sleep_hours",y="daily_social_media_hours",z="daily_social_media_hours",color="depression_lebel",size="TotalRecovered",size_max=100,log_x=True,log_y=True,log_z=True)
        st.plotly_chart(fig5)

        #pie
        fig6=px.pie(df,names="Continent",values="daily_social_media_hours",title="Total Cases By Continent",hover_data=["TotalRecovered","daily_social_media_hours"])
        st.plotly_chart(fig6)

        fig6=px.pie(df,names="Continent",values="daily_social_media_hours",title="Total Cases By Continent",hover_data=["TotalRecovered","daily_social_media_hours"],hole=0.3)
        st.plotly_chart(fig6)

        #sunburst
        fig7=px.sunburst(df,path=["Continent","depression_lebel","sleep_hours"],values="daily_social_media_hours",title="Total Cases By Continent",hover_data=["TotalRecovered","daily_social_media_hours"])
        st.plotly_chart(fig7)
    with t3:
        import seaborn as sns
        import matplotlib.pyplot as plt

        sns.barplot(df,x="gender",y="daily_social_media_hours")
        
        plt.bar(df["gender"],df["daily_social_media_hours"])
        plt.xlabel("gender")
        plt.ylabel("Total Cases")
        plt.title("Total Cases By gender")
        plt.show()
        st.pyplot()


        
elif opt=="About":
    st.title("About")
    st.write("Hello world")